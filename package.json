  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --fix",
    "preview": "vite preview",
    "optimize:cards": "node optimize-images.js ToOptimize public/cards 500",
    "optimize:splash": "node optimize-images.js ToOptimizeSplash public/splash 1920",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ui:demo": "set DEMO=true&&playwright test --ui",
    "test:e2e:demo": "set DEMO=true&&playwright test",
    "test:e2e:report": "playwright show-report",
    "release:patch": "powershell -ExecutionPolicy Bypass -File ./scripts/Release-Project.ps1 -ReleaseType patch",
    "release:minor": "powershell -ExecutionPolicy Bypass -File ./scripts/Release-Project.ps1 -ReleaseType minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File ./scripts/Release-Project.ps1 -ReleaseType major"
  },
  "dependencies": {
