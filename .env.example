# HEXA - Environment Variables Template
# Copy this file to .env.local and fill in the values

# API URL (MockAPI or real backend)
VITE_API_URL=https://your-api-url.mockapi.io/api/v1

# Cloudinary Configuration (Optional - for IA card generation)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_preset

# Gemini/Nano Banana API Key (Required for US8)
VITE_AI_API_KEY=your_api_key_here
